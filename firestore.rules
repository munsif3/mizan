rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function metaPath(householdId) {
      return /databases/$(database)/documents/households/$(householdId)/meta/current;
    }

    function joinRequestPath(householdId, uid) {
      return /databases/$(database)/documents/households/$(householdId)/joinRequests/$(uid);
    }

    function manifestPath(householdId) {
      return /databases/$(database)/documents/households/$(householdId)/snapshotManifest/current;
    }

    function isHouseholdDataCollection(collectionId) {
      return collectionId in [
        "settings",
        "transactions",
        "sharedContributions",
        "accounts",
        "fixedCosts",
        "incomeReceipts",
        "efficiencyPlans",
        "members",
        "customCategories",
        "counterparties",
        "merchantRules",
        "csvPresets",
        "snapshotManifest",
        "snapshots"
      ];
    }

    // Bound the number of top-level fields so a member cannot stuff a document
    // with unbounded arbitrary keys. Real documents stay well under this.
    function withinKeyBudget(data) {
      return data.keys().size() <= 128;
    }

    // The cloud schema version the client currently writes. Keep this in step
    // with CLOUD_HOUSEHOLD_SCHEMA_VERSION in src/household/types.ts. Capping it
    // prevents a member from writing a poison-pill future version that would
    // lock every other member's client out of the household.
    function validVersionField(data) {
      return !("schemaVersion" in data)
        || (data.schemaVersion is int && data.schemaVersion >= 1 && data.schemaVersion <= 9);
    }

    // The snapshot manifest is the compare-and-swap authority for the whole
    // household, so its shape is pinned exactly and its author must be the
    // writer. Other collections carry app-defined payloads and are only size and
    // version bounded.
    function validManifest(collectionId, data) {
      return collectionId != "snapshotManifest"
        || (
          data.keys().hasOnly(["schemaVersion", "activeRevision", "versionToken", "updatedAt", "updatedBy"])
          && data.schemaVersion == 1
          && data.activeRevision is string
          && data.versionToken is string && data.versionToken.size() > 0
          && data.updatedAt is string
          && data.updatedBy == request.auth.uid
        );
    }

    function collectionUsesDocumentId(collectionId) {
      return collectionId in [
        "transactions",
        "sharedContributions",
        "accounts",
        "fixedCosts",
        "incomeReceipts",
        "efficiencyPlans",
        "members",
        "customCategories",
        "counterparties"
      ];
    }

    function validDocumentIdentity(collectionId, docId, data) {
      return !collectionUsesDocumentId(collectionId)
        || (
          data.id is string
          && data.id == docId
          && data.id.size() > 0
          && data.id.size() <= 160
        );
    }

    function validCloudSettings(collectionId, data) {
      return !(collectionId in ["settings", "snapshots"])
        || (
          data.keys().hasOnly(["schemaVersion", "targetSaveRate", "currency", "locale", "fxRates", "updatedAt", "updatedBy"])
          && data.schemaVersion == 9
          && data.targetSaveRate is number
          && data.currency is string && data.currency.size() <= 16
          && data.locale is string && data.locale.size() <= 32
          && data.fxRates is map
          && data.updatedAt is string
          && data.updatedBy == request.auth.uid
        );
    }

    function validKeyedDocument(collectionId, data) {
      return !(
        collectionId in ["merchantRules", "csvPresets"]
      ) || (
        collectionId == "merchantRules"
        && data.keys().hasOnly(["key", "rule", "updatedAt", "updatedBy"])
        && data.key is string && data.key.size() > 0 && data.key.size() <= 512
        && data.rule is map
        && data.updatedAt is string
        && data.updatedBy == request.auth.uid
      ) || (
        collectionId == "csvPresets"
        && data.keys().hasOnly(["signature", "mapping", "updatedAt", "updatedBy"])
        && data.signature is string && data.signature.size() > 0 && data.signature.size() <= 512
        && data.mapping is map
        && data.updatedAt is string
        && data.updatedBy == request.auth.uid
      );
    }

    function validHouseholdDoc(collectionId, docId, data) {
      return withinKeyBudget(data)
        && validVersionField(data)
        && validManifest(collectionId, data)
        && validDocumentIdentity(collectionId, docId, data)
        && validCloudSettings(collectionId, data)
        && validKeyedDocument(collectionId, data);
    }

    function hasVerifiedGoogleIdentity() {
      return "email" in request.auth.token
        && request.auth.token.email is string
        && request.auth.token.email.size() > 0
        && request.auth.token.email_verified == true;
    }

    function validSelfAccessIdentity(access) {
      return hasVerifiedGoogleIdentity()
        && access.email == request.auth.token.email
        && (
          (
            "name" in request.auth.token
            && request.auth.token.name is string
            && request.auth.token.name.size() > 0
            && access.displayName == request.auth.token.name
          )
          || (
            !("name" in request.auth.token)
            && access.displayName == request.auth.token.email
          )
        );
    }

    function isMember(householdId) {
      return signedIn()
        && exists(metaPath(householdId))
        && request.auth.uid in get(metaPath(householdId)).data.membersByUid
        && get(metaPath(householdId)).data.membersByUid[request.auth.uid].role in ["owner", "member"];
    }

    function isMemberAfter(householdId) {
      return signedIn()
        && existsAfter(metaPath(householdId))
        && request.auth.uid in getAfter(metaPath(householdId)).data.membersByUid
        && getAfter(metaPath(householdId)).data.membersByUid[request.auth.uid].role in ["owner", "member"];
    }

    function isOwner(householdId) {
      return signedIn()
        && exists(metaPath(householdId))
        && request.auth.uid in get(metaPath(householdId)).data.membersByUid
        && get(metaPath(householdId)).data.membersByUid[request.auth.uid].role == "owner";
    }

    function validMetaAfter(householdId) {
      return request.resource.data.keys().hasOnly(["id", "name", "ownerUid", "membersByUid", "inviteCode", "createdAt", "updatedAt"])
        && request.resource.data.id == householdId
        && request.resource.data.id == resource.data.id
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.ownerUid in request.resource.data.membersByUid
        && request.resource.data.membersByUid[request.resource.data.ownerUid].role == "owner";
    }

    function isSelfInviteJoin(householdId) {
      return signedIn()
        && !(request.auth.uid in resource.data.membersByUid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["membersByUid", "updatedAt"])
        && request.resource.data.membersByUid.diff(resource.data.membersByUid).affectedKeys().hasOnly([request.auth.uid])
        && request.resource.data.membersByUid[request.auth.uid].keys().hasOnly(["role", "displayName", "email", "joinedAt", "memberId"])
        && request.resource.data.membersByUid[request.auth.uid].role == "member"
        && request.resource.data.membersByUid[request.auth.uid].displayName is string
        && request.resource.data.membersByUid[request.auth.uid].email is string
        && request.resource.data.membersByUid[request.auth.uid].joinedAt is string
        && existsAfter(joinRequestPath(householdId, request.auth.uid))
        && getAfter(joinRequestPath(householdId, request.auth.uid)).data.uid == request.auth.uid
        && getAfter(joinRequestPath(householdId, request.auth.uid)).data.inviteCode == resource.data.inviteCode
        && getAfter(joinRequestPath(householdId, request.auth.uid)).data.createdAt == request.time
        && validSelfAccessIdentity(request.resource.data.membersByUid[request.auth.uid])
        && validMetaAfter(householdId);
    }

    function isSelfLeave(householdId) {
      return signedIn()
        && resource.data.ownerUid != request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["membersByUid", "updatedAt"])
        && request.resource.data.membersByUid.diff(resource.data.membersByUid).affectedKeys().hasOnly([request.auth.uid])
        && request.auth.uid in resource.data.membersByUid
        && !(request.auth.uid in request.resource.data.membersByUid)
        && validMetaAfter(householdId);
    }

    match /households/{householdId}/meta/current {
      allow get: if isMember(householdId);
      allow list: if false;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly(["id", "name", "ownerUid", "membersByUid", "inviteCode", "createdAt", "updatedAt"])
        && request.resource.data.id == householdId
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.membersByUid.keys().hasOnly([request.auth.uid])
        && request.resource.data.membersByUid[request.auth.uid].keys().hasOnly(["role", "displayName", "email", "joinedAt"])
        && request.resource.data.membersByUid[request.auth.uid].role == "owner"
        && validSelfAccessIdentity(request.resource.data.membersByUid[request.auth.uid]);
      allow update: if (isOwner(householdId) && validMetaAfter(householdId))
        || isSelfInviteJoin(householdId)
        || isSelfLeave(householdId);
      allow delete: if isOwner(householdId);
    }

    match /households/{householdId}/joinRequests/{uid} {
      allow create: if signedIn()
        && uid == request.auth.uid
        && request.resource.data.keys().hasOnly(["uid", "inviteCode", "createdAt"])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.inviteCode == get(metaPath(householdId)).data.inviteCode
        && request.resource.data.createdAt == request.time;
      allow read, delete: if signedIn() && (uid == request.auth.uid || isMember(householdId));
      allow update: if false;
    }

    match /households/{householdId}/{collectionId}/{docId} {
      allow read: if isHouseholdDataCollection(collectionId) && isMember(householdId);
      allow create, update: if isHouseholdDataCollection(collectionId)
        && isMemberAfter(householdId)
        && validHouseholdDoc(collectionId, docId, request.resource.data);
      allow delete: if isHouseholdDataCollection(collectionId)
        && collectionId != "snapshotManifest"
        && isMemberAfter(householdId)
        && (
          collectionId != "snapshots"
          || (
            exists(manifestPath(householdId))
            && get(manifestPath(householdId)).data.activeRevision != docId
          )
        );
    }

    match /households/{householdId}/snapshots/{revision}/{collectionId}/{docId} {
      allow read: if isHouseholdDataCollection(collectionId) && isMember(householdId);
      allow create, update: if isHouseholdDataCollection(collectionId)
        && isMemberAfter(householdId)
        && validHouseholdDoc(collectionId, docId, request.resource.data);
      allow delete: if isHouseholdDataCollection(collectionId)
        && isMemberAfter(householdId)
        && (
          (
            exists(manifestPath(householdId))
            && get(manifestPath(householdId)).data.activeRevision != revision
          )
          || (
            exists(manifestPath(householdId))
            && existsAfter(manifestPath(householdId))
            && get(manifestPath(householdId)).data.activeRevision == revision
            && getAfter(manifestPath(householdId)).data.activeRevision == revision
            && getAfter(manifestPath(householdId)).data.versionToken != get(manifestPath(householdId)).data.versionToken
            && getAfter(manifestPath(householdId)).data.updatedBy == request.auth.uid
          )
        );
    }

    match /users/{uid}/households/{householdId} {
      function validLinkAfter() {
        return existsAfter(metaPath(householdId))
          && uid in getAfter(metaPath(householdId)).data.membersByUid
          && request.resource.data.keys().hasOnly(["householdId", "name", "role", "joinedAt", "updatedAt"])
          && request.resource.data.householdId == householdId
          && request.resource.data.name == getAfter(metaPath(householdId)).data.name
          && request.resource.data.role == getAfter(metaPath(householdId)).data.membersByUid[uid].role
          && request.resource.data.joinedAt == getAfter(metaPath(householdId)).data.membersByUid[uid].joinedAt
          && request.resource.data.updatedAt is string;
      }

      allow read: if signedIn() && (request.auth.uid == uid || isOwner(householdId));
      allow create: if signedIn() && request.auth.uid == uid && validLinkAfter();
      allow update: if signedIn()
        && validLinkAfter()
        && (
          request.auth.uid == uid
          || (
            isOwner(householdId)
            && uid in get(metaPath(householdId)).data.membersByUid
          )
        );
      allow delete: if signedIn()
        && (
          request.auth.uid == uid
          || (
            isOwner(householdId)
            && uid in get(metaPath(householdId)).data.membersByUid
            && existsAfter(metaPath(householdId))
            && !(uid in getAfter(metaPath(householdId)).data.membersByUid)
          )
        );
    }

    match /users/{uid}/profile/current {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

{
  "name": "mizan",
  "private": true,
  "version": "1.0.0",
  "description": "Deterministic household finance PWA with Google sign-in and Firestore sync.",
  "license": "MIT",
  "type": "module",
  "packageManager": "npm@11.8.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "check:styles": "vitest run scripts/style-system.test.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rules:emulator": "vitest run --config vitest.rules.config.ts",
    "test:rules": "firebase emulators:exec --only firestore --project demo-mizan \"npm run test:rules:emulator\"",
    "typecheck": "tsc --noEmit",
    "check:deadcode": "knip",
    "check": "npm run typecheck && npm run check:styles && npm test && vite build"
  },
  "dependencies": {
    "firebase": "^12.16.0",
    "lucide-react": "^1.24.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/crypto-js": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "crypto-js": "^4.2.0",
    "firebase-tools": "^15.24.0",
    "jsdom": "^29.1.1",
    "knip": "6.26.0",
    "pdf-lib": "^1.17.1",
    "postcss": "^8.5.16",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
